# --- Font & Text ---
# Using Departure Mono for that clinical Alien look
#font-family = "Departure Mono"
font-family = "Glass TTY VT220"
font-size = 16
font-thicken = true

# --- Theme Section ---
theme = ENCOM

# Custom Overrides (Must stay BELOW the theme line)
palette = 2=#00e5ff
palette = 10=#00e5ff

# ADD THIS LINE: Define Color 4 as a deeper, darker cyan for folders
palette = 4=#008b8b

# Red Error Fixes
palette = 1=#ff0000
palette = 9=#ff3333

foreground = #00e5ff
cursor-color = #00e5ff
background = #000000

# --- Window Look & Feel ---
window-decoration = false
window-padding-x = 20
window-padding-y = 20
background-opacity = 0.90

# --- Cursor (MU/TH/UR Style) ---
cursor-style = block
cursor-style-blink = false

# --- Shell Integration ---
# This is the critical fix: we combine your features into ONE line
# and include 'no-cursor' so Zsh doesn't break your block cursor.
shell-integration = detect
shell-integration-features = sudo,ssh-env,no-cursor

# --- Shaders (The Nostromo Screen) ---
custom-shader = ~/.config/ghostty/shaders/tft.glsl
custom-shader = ~/.config/ghostty/shaders/bettercrt.glsl
custom-shader = ~/.config/ghostty/shaders/bloom.glsl
custom-shader-animation = always

# --- Performance & Misc ---
scrollback-limit = 10000